{
  "name": "taskflow",
  "version": "1.0.1",
  "description": "Personal task management desktop app",
  "main": "out/main/main.js",
  "author": "TaskFlow",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite --config vite.config.ts",
